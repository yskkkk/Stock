{
  "name": "stock-chart-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:guard": "node scripts/dev-server-guard.mjs",
    "dev:watch": "node scripts/laptop-git-watch-dev.mjs",
    "i18n:gen": "node scripts/gen-ko-i18n.mjs",
    "verify": "node scripts/gen-server-offline-html.mjs && node scripts/verify-encoding.mjs",
    "verify:entry": "node scripts/verify-entry-http.mjs",
    "verify:api-smoke": "node scripts/verify-api-smoke.mjs",
    "verify:express-spa": "node scripts/verify-express-spa-root.mjs",
    "test": "vitest run",
    "build": "npm run verify && tsc -b && vite build",
    "build:mobile": "vite build --mode capacitor && npx cap sync",
    "apk:build": "node scripts/build-android-apk.mjs",
    "ipa:build": "node scripts/build-ios-ipa.mjs",
    "ios:ota-check": "node scripts/check-ios-ota-ready.mjs",
    "ios:build": "node scripts/build-ios-ipa.mjs",
    "ios:open": "node scripts/open-ios-xcode.mjs",
    "app:build": "node scripts/build-android-apk.mjs",
    "icons:gen": "node scripts/gen-pwa-icons.mjs",
    "email:box-range-strategy": "node scripts/send-box-range-strategy-email.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "preview": "concurrently -k \"node server/index.js\" \"vite preview\""
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@cursor/sdk": "^1.0.13",
    "@vscode/ripgrep": "^1.18.0",
    "express": "^5.1.0",
    "lightweight-charts": "^5.0.7",
    "nodemailer": "^8.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "tree-kill": "^1.2.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
