// 차트 TF 횡보 박스만(흰 사각형·추세선 없음) → pine-box-consolidation-zones.pine

//@version=6
indicator("수평 매물대 · 박스권 MTF", shorttitle="박스권 MTF", overlay=true, max_boxes_count=500, max_lines_count=500, max_bars_back=5000)

// ── 1H / 4H / 1D 프리셋 ─────────────────────────────────────────────
H1_LB       = 16
H1_MIN      = 6
H1_MAX_PCT  = 3.2
H1_ATR_LEN  = 14
H1_ATR_MULT = 2.0
H1_MERGE_P  = 1.0
H1_MERGE_B  = 0
H1_EXT_B    = 10
H1_EXIT_B   = 2

H4_LB       = 14
H4_MIN      = 5
H4_MAX_PCT  = 4.5
H4_ATR_LEN  = 14
H4_ATR_MULT = 2.0
H4_MERGE_P  = 1.2
H4_MERGE_B  = 0
H4_EXT_B    = 8
H4_EXIT_B   = 2

D1_LB       = 12
D1_MIN      = 4
D1_MAX_PCT  = 7.0
D1_ATR_LEN  = 14
D1_ATR_MULT = 2.0
D1_MERGE_P  = 1.5
D1_MERGE_B  = 0
D1_EXT_B    = 6
D1_EXIT_B   = 2

TF_SEC_1H = 3600
TF_SEC_4H = 14400
TF_SEC_1D = 86400

// ── 표시 · 대시보드 ─────────────────────────────────────────────────
grpVis = "표시"
// 1H 박스 → 1H 차트에서만, 4H → 4H, 1D → 일봉 (다른 TF 겹침 없음)
int chartTfSec = timeframe.in_seconds()
bool vis1H = chartTfSec == TF_SEC_1H
bool vis4H = chartTfSec == TF_SEC_4H
bool vis1D = timeframe.isdaily or chartTfSec == TF_SEC_1D
completedOnly = input.bool(true, "완성 박스만", group=grpVis, tooltip="실시간 봉에서 진행 중(점선) 박스 미표시 · 리페인트 완화")
showActive  = input.bool(false, "진행 중 박스", group=grpVis, tooltip="완성 박스만=켜도 점선은 안 그림")
zonesPerTf  = input.int(0, "TF당 표시 개수 (0=전체)", minval=0, maxval=500, group=grpVis)
showDash    = input.bool(true, "대시보드", group=grpVis)
dashPos     = input.string("우상단", "대시보드 위치", options=["우상단", "우하단", "좌상단", "좌하단"], group=grpVis)

grpCol = "색상"
col1H_fill  = input.color(color.new(#2962FF, 84), "1H 채움", group=grpCol)
col1H_brd   = input.color(color.new(#2962FF, 40), "1H 테두리", group=grpCol)
col1H_mid   = input.color(color.new(#2962FF, 0), "1H 중심", group=grpCol)
col4H_fill  = input.color(color.new(#7B1FA2, 86), "4H 채움", group=grpCol)
col4H_brd   = input.color(color.new(#7B1FA2, 42), "4H 테두리", group=grpCol)
col4H_mid   = input.color(color.new(#CE93D8, 0), "4H 중심", group=grpCol)
col1D_fill  = input.color(color.new(#FF6D00, 88), "1D 채움", group=grpCol)
col1D_brd   = input.color(color.new(#FF6D00, 45), "1D 테두리", group=grpCol)
col1D_mid   = input.color(color.new(#FF6D00, 0), "1D 중심", group=grpCol)
midWidth    = input.int(2, "중심선 두께", minval=1, maxval=4, group=grpCol)

grpAdv = "고급 (프리셋 덮어쓰기)"
useCustom   = input.bool(false, "수동 인풋 사용", group=grpAdv, tooltip="끄면 1H/4H/1D 프리셋 고정. 켜면 아래 값이 세 TF 공통 적용")
usePctLimit = input.bool(false, "폭 % 제한", group=grpAdv, tooltip="끄면 박스 높이(%)로 시작·종료하지 않음 — 넓은 횡보도 표시")
useAtrCap   = input.bool(false, "ATR 폭 보조(폭% 켤 때)", group=grpAdv)
breakAtrMult = input.float(0.45, "이탈 ATR 배수", minval=0.1, maxval=3.0, step=0.05, group=grpAdv, tooltip="폭 % 제한 끌 때 종가가 박스 밖 ATR×배수로 종료")
cLookback   = input.int(16, "구간(봉)", minval=5, group=grpAdv)
cMinBars    = input.int(6, "최소 박스 봉", minval=3, group=grpAdv)
cMaxPct     = input.float(3.5, "최대 폭(%)", minval=0.5, step=0.1, group=grpAdv, tooltip="폭 % 제한 켤 때만")
cMergeMidPct = input.float(1.0, "병합 중심 허용(%)", minval=0.1, maxval=8.0, step=0.1, group=grpAdv, tooltip="두 박스 중심가 차이가 이 값(중간가 대비 %) 이하일 때만 병합 · 겹침만으로는 합치지 않음")
cMergeBars  = input.int(0, "병합 시간(봉, 0=시간무시)", minval=0, group=grpAdv)

float NO_PCT = 99999.0

f_pos(string p) =>
    p == "우하단" ? position.bottom_right : p == "좌상단" ? position.top_left : p == "좌하단" ? position.bottom_left : position.top_right

// ── 병합: 중심가(평균) 근접 + 시간만 — 가격대만 겹치면 합치지 않음 ─────
f_timeNear(int tEnd, int tStart, int mBars, int tfSec) =>
    int gap = mBars * tfSec * 1000
    mBars <= 0 ? true : math.abs(tStart - tEnd) <= gap

f_midDistancePct(float t1, float b1, float t2, float b2) =>
    float m1 = (t1 + b1) * 0.5
    float m2 = (t2 + b2) * 0.5
    float ref = (m1 + m2) * 0.5
    ref > 0 ? math.abs(m1 - m2) / ref * 100.0 : 100.0

f_midNear(float t1, float b1, float t2, float b2, float maxMidPct) =>
    f_midDistancePct(t1, b1, t2, b2) <= maxMidPct

f_shouldMerge(float tN, float bN, int t0N, int t1N, float tO, float bO, int t0O, int t1O, float maxMidPct, int mBars, int tfSec) =>
    bool midOk = f_midNear(tN, bN, tO, bO, maxMidPct)
    bool timeOk = f_timeNear(t1N, t0O, mBars, tfSec) or f_timeNear(t1O, t0N, mBars, tfSec)
    midOk and timeOk

f_mergePair(float tN, float bN, int t0N, int t1N, float tO, float bO, int t0O, int t1O) =>
    [math.max(tN, tO), math.min(bN, bO), math.min(t0N, t0O), math.max(t1N, t1O)]

f_pushMerged(float[] tops, float[] bots, int[] t0s, int[] t1s, float tN, float bN, int t0N, int t1N, float mPct, int mBars, int tfSec) =>
    array.unshift(tops, tN)
    array.unshift(bots, bN)
    array.unshift(t0s, t0N)
    array.unshift(t1s, t1N)
    bool did = true
    while did
        did := false
        int i = 0
        while i < array.size(tops)
            float mt = array.get(tops, i)
            float mb = array.get(bots, i)
            int ma = array.get(t0s, i)
            int me = array.get(t1s, i)
            int j = i + 1
            while j < array.size(tops)
                float tO = array.get(tops, j)
                float bO = array.get(bots, j)
                int t0O = array.get(t0s, j)
                int t1O = array.get(t1s, j)
                if f_shouldMerge(mt, mb, ma, me, tO, bO, t0O, t1O, mPct, mBars, tfSec)
                    [mt, mb, ma, me] = f_mergePair(mt, mb, ma, me, tO, bO, t0O, t1O)
                    array.set(tops, i, mt)
                    array.set(bots, i, mb)
                    array.set(t0s, i, ma)
                    array.set(t1s, i, me)
                    array.remove(tops, j)
                    array.remove(bots, j)
                    array.remove(t0s, j)
                    array.remove(t1s, j)
                    did := true
                else
                    j += 1
            i += 1

// ── 박스 엔진 (HTF · 배열 저장 무제한) ───────────────────────────────
f_zoneEngine(
     int lb, int minB, float maxPct, bool useAtr, int atrL, float atrM,
     float mPct, int mBars, int tfSec, int extBars, int exitBars,
     bool pctLimit, float brkAtr) =>
    rngHi = ta.highest(high, lb)
    rngLo = ta.lowest(low, lb)
    midPx = (rngHi + rngLo) * 0.5
    rangePct = midPx > 0 ? (rngHi - rngLo) / midPx * 100.0 : 100.0
    atrVal = ta.atr(atrL)
    atrPct = close > 0 ? atrVal / close * 100.0 * atrM : rangePct
    capPct = pctLimit ? (useAtr ? math.min(maxPct, math.max(maxPct * 0.5, atrPct)) : maxPct) : NO_PCT
    bool rollTight = pctLimit ? rangePct <= capPct : true

    var int   stT0 = na
    var int   stCnt = 0
    var int   looseCnt = 0
    var float stTop = na
    var float stBot = na
    var float[] zTop = array.new_float()
    var float[] zBot = array.new_float()
    var int[]   zT0 = array.new_int()
    var int[]   zT1 = array.new_int()

    int extMs = extBars * tfSec * 1000

    float trkMid = not na(stTop) and not na(stBot) ? (stTop + stBot) * 0.5 : midPx
    float trkPct = not na(stTop) and not na(stBot) and trkMid > 0 ? (stTop - stBot) / trkMid * 100.0 : rangePct
    float brkBuf = atrVal * brkAtr
    bool pctWide = stCnt > 0 and pctLimit and trkPct > capPct * 1.25
    bool atrBreak = stCnt > 0 and not pctLimit and not na(stTop) and not na(stBot) and (close > stTop + brkBuf or close < stBot - brkBuf)
    bool wideBreak = pctWide or atrBreak
    bool inBox = stCnt > 0 and not wideBreak

    if stCnt > 0
        looseCnt := (pctLimit and not rollTight) ? looseCnt + 1 : 0
        if wideBreak or (pctLimit and looseCnt >= exitBars)
            if stCnt >= minB and not na(stTop)
                f_pushMerged(zTop, zBot, zT0, zT1, stTop, stBot, stT0, time, mPct, mBars, tfSec)
            stT0 := na
            stCnt := 0
            looseCnt := 0
            stTop := na
            stBot := na

    if stCnt == 0 and rollTight
        stT0 := time
        stCnt := 1
        looseCnt := 0
        stTop := high
        stBot := low
    else if stCnt > 0 and inBox
        stCnt += 1
        stTop := math.max(stTop, high)
        stBot := math.min(stBot, low)

    bool actOn = stCnt >= minB and inBox
    float actTop = actOn ? stTop : na
    float actBot = actOn ? stBot : na
    float actMid = actOn ? (stTop + stBot) * 0.5 : na
    int actT0 = actOn ? stT0 : na
    int actT1 = actOn ? time + extMs : na
    int zn = array.size(zTop)
    bool inR = rollTight or actOn
    [inR, rangePct, actOn, actTop, actBot, actMid, actT0, actT1, zn, zTop, zBot, zT0, zT1]

h1_lb = useCustom ? cLookback : H1_LB
h1_min = useCustom ? cMinBars : H1_MIN
h1_pct = useCustom ? cMaxPct : H1_MAX_PCT
h1_mp = useCustom ? cMergeMidPct : H1_MERGE_P
h1_mb = useCustom ? cMergeBars : H1_MERGE_B

sym = syminfo.tickerid
bool atrOn = usePctLimit and useAtrCap
bool pctLim = usePctLimit

[h1_in, h1_rp, h1_act, h1_at, h1_ab, h1_am, h1_a0, h1_a1, h1_zn, h1_zTop, h1_zBot, h1_zT0, h1_zT1] =
     request.security(sym, "60", f_zoneEngine(h1_lb, h1_min, h1_pct, atrOn, H1_ATR_LEN, H1_ATR_MULT, h1_mp, h1_mb, TF_SEC_1H, H1_EXT_B, H1_EXIT_B, pctLim, breakAtrMult), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

[h4_in, h4_rp, h4_act, h4_at, h4_ab, h4_am, h4_a0, h4_a1, h4_zn, h4_zTop, h4_zBot, h4_zT0, h4_zT1] =
     request.security(sym, "240", f_zoneEngine(useCustom ? cLookback : H4_LB, useCustom ? cMinBars : H4_MIN, useCustom ? cMaxPct : H4_MAX_PCT, atrOn, H4_ATR_LEN, H4_ATR_MULT, useCustom ? cMergePct : H4_MERGE_P, useCustom ? cMergeBars : H4_MERGE_B, TF_SEC_4H, H4_EXT_B, H4_EXIT_B, pctLim, breakAtrMult), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

[d_in, d_rp, d_act, d_at, d_ab, d_am, d_a0, d_a1, d_zn, d_zTop, d_zBot, d_zT0, d_zT1] =
     request.security(sym, "D", f_zoneEngine(useCustom ? cLookback : D1_LB, useCustom ? cMinBars : D1_MIN, useCustom ? cMaxPct : D1_MAX_PCT, atrOn, D1_ATR_LEN, D1_ATR_MULT, useCustom ? cMergePct : D1_MERGE_P, useCustom ? cMergeBars : D1_MERGE_B, TF_SEC_1D, D1_EXT_B, D1_EXIT_B, pctLim, breakAtrMult), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

// ── 그리기 ─────────────────────────────────────────────────────────
var box[]  b1h = array.new_box()
var line[] l1h = array.new_line()
var box[]  b4h = array.new_box()
var line[] l4h = array.new_line()
var box[]  b1d = array.new_box()
var line[] l1d = array.new_line()

f_clearTf(box[] bx, line[] ln) =>
    while array.size(bx) > 0
        box.delete(array.pop(bx))
    while array.size(ln) > 0
        line.delete(array.pop(ln))

f_fmt(float v) =>
    na(v) ? "—" : str.tostring(v, format.mintick)

f_widthPct(float t, float b) =>
    float m = (t + b) * 0.5
    m > 0 ? str.tostring((t - b) / m * 100, "#.##") + "%" : "—"

f_drawZone(box[] bx, line[] ln, int t0, int t1, float top, float bot, color fill, color brd, color mid, bool dashed) =>
    if not na(top) and not na(bot) and not na(t0) and not na(t1) and top > bot
        int tL = math.min(t0, t1)
        int tR = math.max(t0, t1)
        float avg = (top + bot) * 0.5
        box nb = box.new(tL, top, tR, bot, xloc = xloc.bar_time, bgcolor = fill, border_color = brd, border_width = 1, border_style = dashed ? line.style_dashed : line.style_solid)
        line nl = line.new(tL, avg, tR, avg, xloc = xloc.bar_time, color = mid, width = midWidth, style = line.style_solid)
        array.push(bx, nb)
        array.push(ln, nl)

f_drawTfArrays(bool en, box[] bx, line[] ln, bool actOn, int a0, int a1, float at, float ab, color fill, color brd, color mid, int nCap, float[] tops, float[] bots, int[] t0s, int[] t1s, int extMs) =>
    if en and barstate.isconfirmed
        bool drawAct = actOn and showActive and not completedOnly
        if drawAct
            f_drawZone(bx, ln, a0, a1, at, ab, color.new(fill, 88), brd, mid, true)
        int total = math.min(array.size(tops), array.size(bots), array.size(t0s), array.size(t1s))
        if total > 0
            int n = nCap <= 0 ? total : math.min(nCap, total)
            for i = 0 to n - 1
                float top = array.get(tops, i)
                float bot = array.get(bots, i)
                int t0 = array.get(t0s, i)
                int t1 = array.get(t1s, i) + extMs
                f_drawZone(bx, ln, t0, t1, top, bot, fill, brd, mid, false)

f_dashFromZones(bool actOn, float at, float ab, float am, float[] tops, float[] bots) =>
    if actOn
        [at, ab, am]
    else if array.size(tops) > 0
        float t = array.get(tops, 0)
        float b = array.get(bots, 0)
        [t, b, (t + b) * 0.5]
    else
        [na, na, na]

f_status(bool inR, bool actOn) =>
    actOn ? "박스중" : inR ? "형성" : "—"

if barstate.isconfirmed
    f_clearTf(b1h, l1h)
    f_clearTf(b4h, l4h)
    f_clearTf(b1d, l1d)
    f_drawTfArrays(vis1H, b1h, l1h, h1_act, h1_a0, h1_a1, h1_at, h1_ab, col1H_fill, col1H_brd, col1H_mid, zonesPerTf, h1_zTop, h1_zBot, h1_zT0, h1_zT1, H1_EXT_B * TF_SEC_1H * 1000)
    f_drawTfArrays(vis4H, b4h, l4h, h4_act, h4_a0, h4_a1, h4_at, h4_ab, col4H_fill, col4H_brd, col4H_mid, zonesPerTf, h4_zTop, h4_zBot, h4_zT0, h4_zT1, H4_EXT_B * TF_SEC_4H * 1000)
    f_drawTfArrays(vis1D, b1d, l1d, d_act, d_a0, d_a1, d_at, d_ab, col1D_fill, col1D_brd, col1D_mid, zonesPerTf, d_zTop, d_zBot, d_zT0, d_zT1, D1_EXT_B * TF_SEC_1D * 1000)

// ── 대시보드 ───────────────────────────────────────────────────────
var table dash = table.new(f_pos(dashPos), 6, 5, bgcolor = color.new(#1E1E1E, 8), border_width = 1, border_color = color.new(#ffffff, 75))

f_dashRow(table tb, int row, string tf, color tc, bool inR, bool actOn, float top, float bot, float mid, float rp, int zn) =>
    string st = f_status(inR, actOn)
    color stCol = actOn ? color.new(#66BB6A, 0) : inR ? color.new(#FFA726, 0) : color.new(#9E9E9E, 30)
    table.cell(tb, 0, row, tf, text_color = tc, text_size = size.small)
    table.cell(tb, 1, row, st, text_color = stCol, text_size = size.small)
    table.cell(tb, 2, row, f_fmt(top), text_color = color.white, text_size = size.small)
    table.cell(tb, 3, row, f_fmt(bot), text_color = color.white, text_size = size.small)
    table.cell(tb, 4, row, f_fmt(mid), text_color = color.white, text_size = size.small)
    string w = (actOn or not na(top)) and not na(bot) ? f_widthPct(top, bot) : str.tostring(rp, "#.##") + "%"
    table.cell(tb, 5, row, w + " · " + str.tostring(zn), text_color = color.new(#B0BEC5, 0), text_size = size.tiny)

bool dashAct1H = completedOnly ? false : h1_act
bool dashAct4H = completedOnly ? false : h4_act
bool dashAct1D = completedOnly ? false : d_act

if showDash and barstate.isconfirmed
    table.cell(dash, 0, 0, "TF", text_color = color.gray, text_size = size.tiny)
    table.cell(dash, 1, 0, "상태", text_color = color.gray, text_size = size.tiny)
    table.cell(dash, 2, 0, "상단", text_color = color.gray, text_size = size.tiny)
    table.cell(dash, 3, 0, "하단", text_color = color.gray, text_size = size.tiny)
    table.cell(dash, 4, 0, "중심", text_color = color.gray, text_size = size.tiny)
    table.cell(dash, 5, 0, "폭/저장", text_color = color.gray, text_size = size.tiny)

    int dRow = 1
    if vis1H
        [h1_dt, h1_db, h1_dm] = f_dashFromZones(dashAct1H, h1_at, h1_ab, h1_am, h1_zTop, h1_zBot)
        f_dashRow(dash, dRow, "1H", col1H_mid, h1_in, dashAct1H, h1_dt, h1_db, h1_dm, h1_rp, h1_zn)
        dRow += 1
    if vis4H
        [h4_dt, h4_db, h4_dm] = f_dashFromZones(dashAct4H, h4_at, h4_ab, h4_am, h4_zTop, h4_zBot)
        f_dashRow(dash, dRow, "4H", col4H_mid, h4_in, dashAct4H, h4_dt, h4_db, h4_dm, h4_rp, h4_zn)
        dRow += 1
    if vis1D
        [d_dt, d_db, d_dm] = f_dashFromZones(dashAct1D, d_at, d_ab, d_am, d_zTop, d_zBot)
        f_dashRow(dash, dRow, "1D", col1D_mid, d_in, dashAct1D, d_dt, d_db, d_dm, d_rp, d_zn)
        dRow += 1

    string capTxt = zonesPerTf <= 0 ? "전체" : str.tostring(zonesPerTf)
    string tfNote = vis1H ? "1H" : vis4H ? "4H" : vis1D ? "1D" : "—"
    string preset = tfNote + " 차트만 · " + (usePctLimit ? "폭%제한" : "폭%없음") + " · " + capTxt + (completedOnly ? " · 완성만" : "")
    table.cell(dash, 0, 4, preset, text_color = color.new(#78909C, 0), text_size = size.tiny)
    table.merge_cells(dash, 0, 4, 5, 4)
