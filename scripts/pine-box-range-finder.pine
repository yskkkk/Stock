// 박스권(횡보) 탐지 — TradingView Pine v6

//@version=6
indicator("박스권 Finder", shorttitle="박스Finder", overlay=true, max_boxes_count=500, max_lines_count=500, max_bars_back=5000)

grpCore = "핵심"
preset      = input.string("보통", "민감도", options=["느슨", "보통", "엄격"], group=grpCore)
boxLen      = input.int(12, "박스 길이(봉)", minval=4, maxval=40, group=grpCore)
minBoxBars  = input.int(4, "최소 봉 수", minval=3, maxval=50, group=grpCore)
maxBoxPct   = input.float(8.0, "박스 최대 높이(%)", minval=0.5, maxval=25.0, step=0.5, group=grpCore, tooltip="일봉은 8~15%, 1H는 3~6% 권장")
breakAtr    = input.float(0.45, "이탈 ATR 배수", minval=0.1, maxval=2.0, step=0.05, group=grpCore)
cooldown    = input.int(1, "박스 사이 쿨다운(봉)", minval=0, maxval=20, group=grpCore)
enterBars   = input.int(2, "시작 확인(봉)", minval=1, maxval=5, group=grpCore)
graceBars   = input.int(2, "이탈 허용(봉)", minval=0, maxval=10, group=grpCore)

grpFilt = "횡보 필터"
useRank     = input.bool(false, "폭 순위 필터", group=grpFilt, tooltip="켜면 최근 대비 좁은 구간만 — 꺼두면 박스가 더 잘 보임")
adxLen      = input.int(14, "ADX", minval=5, group=grpFilt)
maxAdx      = input.float(28.0, "ADX 상한", minval=5.0, maxval=50.0, step=0.5, group=grpFilt)
maxEr       = input.float(0.50, "효율비(ER) 상한", minval=0.05, maxval=0.9, step=0.02, group=grpFilt)
rankLen     = input.int(80, "폭 순위 기간", minval=20, maxval=300, group=grpFilt)
maxRank     = input.int(45, "폭 순위 상한(%)", minval=5, maxval=80, group=grpFilt)

grpVis = "표시"
onlyDone    = input.bool(false, "완성 박스만", group=grpVis)
showLive    = input.bool(true, "진행 중", group=grpVis)
extendR     = input.int(3, "우측 연장(봉)", minval=0, maxval=20, group=grpVis)
maxBoxes    = input.int(30, "최대 개수(0=전체)", minval=0, maxval=250, group=grpVis)
showMid     = input.bool(false, "중심선", group=grpVis)
showCandBg  = input.bool(true, "횡보 후보 배경", group=grpVis)

grpCol = "색"
cFill  = input.color(color.new(#5C6BC0, 80), "채움", group=grpCol)
cBrd   = input.color(color.new(#283593, 0), "테두리", group=grpCol)
cMid   = input.color(color.new(#FFEE58, 25), "중심", group=grpCol)
cLive  = input.color(color.new(#5C6BC0, 88), "진행", group=grpCol)
cCand   = input.color(color.new(#5C6BC0, 93), "후보 배경", group=grpCol)

float pMaxBox = preset == "엄격" ? math.min(maxBoxPct, 4.0) : preset == "느슨" ? maxBoxPct * 1.4 : maxBoxPct
float pMaxEr = preset == "엄격" ? math.min(maxEr, 0.35) : preset == "느슨" ? maxEr * 1.2 : maxEr
float pMaxAdx = preset == "엄격" ? math.min(maxAdx, 22.0) : preset == "느슨" ? maxAdx * 1.15 : maxAdx
int pMaxRank = preset == "엄격" ? math.min(maxRank, 30) : preset == "느슨" ? math.min(maxRank + 25, 80) : maxRank

float boxMid = (ta.highest(high, boxLen) + ta.lowest(low, boxLen)) * 0.5
float boxH   = ta.highest(high, boxLen) - ta.lowest(low, boxLen)
float boxPct = boxMid > 0 ? boxH / boxMid * 100.0 : 100.0

float absChg = math.abs(close - close[1])
float path = ta.sma(absChg, boxLen) * boxLen
float er   = path > 0 ? math.abs(close - close[boxLen]) / path : 1.0

[_, _, adx] = ta.dmi(adxLen, adxLen)
float rank = ta.percentrank(boxPct, rankLen)

bool isFlat = boxPct <= pMaxBox
bool isChop = er <= pMaxEr
bool isWeakTrend = adx <= pMaxAdx
bool isNarrowHist = not useRank or rank <= pMaxRank

bool canRange = isFlat and isChop and isWeakTrend and isNarrowHist

var int   bStart = na
var int   bCount = 0
var float bTop   = na
var float bBot   = na
var int   coolLeft = 0
var int   flatRun = 0
var int   missRun = 0

var float[] doneTop = array.new_float()
var float[] doneBot = array.new_float()
var int[]   doneT0  = array.new_int()
var int[]   doneT1  = array.new_int()

float atr = ta.atr(14)
int extMs = extendR * timeframe.in_seconds() * 1000

f_boxPct(float t, float b) =>
    float m = (t + b) * 0.5
    m > 0 ? (t - b) / m * 100.0 : 100.0

f_closeOutside(float t, float b, float mult) =>
    float buf = atr * mult
    close > t + buf or close < b - buf

if coolLeft > 0
    coolLeft -= 1

flatRun := canRange ? flatRun + 1 : 0
bool readyStart = flatRun >= enterBars

bool inTrack = bCount > 0
float livePct = inTrack ? f_boxPct(bTop, bBot) : boxPct
bool tooWide = inTrack and livePct > pMaxBox * 1.2
bool broke = inTrack and f_closeOutside(bTop, bBot, breakAtr)

if inTrack
    missRun := canRange ? 0 : missRun + 1
else
    missRun := 0

bool lostFlat = inTrack and missRun > graceBars

if inTrack and (tooWide or broke or lostFlat)
    if bCount >= minBoxBars
        array.unshift(doneTop, bTop)
        array.unshift(doneBot, bBot)
        array.unshift(doneT0, bStart)
        array.unshift(doneT1, time[1])
    bStart := na
    bCount := 0
    bTop := na
    bBot := na
    coolLeft := cooldown
    missRun := 0

if bCount == 0 and coolLeft <= 0 and readyStart
    bStart := time
    bCount := 1
    bTop := high
    bBot := low
    missRun := 0

else if inTrack and not (tooWide or broke or lostFlat)
    bCount += 1
    bTop := math.max(bTop, high)
    bBot := math.min(bBot, low)

bool liveOn = bCount >= math.max(3, minBoxBars - 1) and inTrack
float liveTop = liveOn ? bTop : na
float liveBot = liveOn ? bBot : na
int liveT0 = liveOn ? bStart : na
int liveT1 = liveOn ? time + extMs : na

bgcolor(showCandBg and canRange ? cCand : na, title="횡보 후보")

var box[]  gBox = array.new_box()
var line[] gLn  = array.new_line()

f_wipe() =>
    while array.size(gBox) > 0
        box.delete(array.pop(gBox))
    while array.size(gLn) > 0
        line.delete(array.pop(gLn))

f_paint(int t0, int t1, float top, float bot, color fill, color brd, bool dash) =>
    if not na(t0) and not na(t1) and not na(top) and not na(bot) and top > bot
        int tL = math.min(t0, t1)
        int tR = math.max(t0, t1)
        array.push(gBox, box.new(tL, top, tR, bot, xloc=xloc.bar_time, bgcolor=fill, border_color=brd, border_width=2, border_style=dash ? line.style_dashed : line.style_solid))
        if showMid
            float mid = (top + bot) * 0.5
            array.push(gLn, line.new(tL, mid, tR, mid, xloc=xloc.bar_time, color=cMid, width=1))

if barstate.islastconfirmedhistory or barstate.isconfirmed
    f_wipe()
    bool paintLive = liveOn and showLive and (not onlyDone or barstate.islast)
    if paintLive
        f_paint(liveT0, liveT1, liveTop, liveBot, cLive, cBrd, true)
    int n = array.size(doneTop)
    if n > 0
        int lim = maxBoxes <= 0 ? n : math.min(maxBoxes, n)
        for i = 0 to lim - 1
            f_paint(array.get(doneT0, i), array.get(doneT1, i) + extMs, array.get(doneTop, i), array.get(doneBot, i), cFill, cBrd, false)

plot(boxPct, "창 폭%", display=display.data_window)
plot(canRange ? 1 : 0, "횡보OK", display=display.data_window)
plot(array.size(doneTop), "완성박스수", display=display.data_window)
