// 통합 박스권 감지기 PRO — TradingView Pine v5
// 중심 수평선: 첫 매수 봉까지만 · 가로 확장: 종가가 중심에서 TF별 반높이 % 이탈 시 중단

//@version=5
indicator("통합 박스권 감지기 PRO", overlay=true, max_boxes_count=500, max_lines_count=500)

string active_tf = input.string("D", "분석 타임프레임", options=["60", "240", "D"])
int min_days = input.int(14, "최소 기간", minval=14)
float merge_pct = input.float(35.0, "박스 병합: 가격 겹침 %", minval=10, maxval=90)
int merge_bars = input.int(5, "박스 병합: 좌우 봉 간격", minval=0)
int max_expand_bars = input.int(120, "좌우 확장 최대(봉)", minval=20, maxval=300)
float expand_edge_pct = input.float(12.0, "확장 허용(박스높이 %)", minval=2.0, maxval=40.0, step=0.5, tooltip="시드 박스 밖으로 이만큼까지는 같은 박스로 봄")
int expand_gap_bars = input.int(2, "확장 끊김(연속 이탈 봉)", minval=1, maxval=6, tooltip="이 봉 수 연속으로 박스 밖이면 좌·우 확장 중단")

bool show_buy = input.bool(true, "매수 신호")
bool show_sell = input.bool(true, "매도 신호")

float max_box_pct = 15.0
if active_tf == "60"
    max_box_pct := 3.0
else if active_tf == "240"
    max_box_pct := 5.0

bool split_tf_preset = input.bool(true, "TF별 중심 이탈 % 프리셋", tooltip="1H 28 / 4H 38 / 1D 48. 끄면 아래 수동 값 사용")
float split_mid_manual = input.float(48.0, "중심 이탈 한계(반높이 %)", minval=10, maxval=80, step=1.0, tooltip="종가가 중심에서 반높이×이 % 이상 벗어나면 가로 확장 중단")
float split_mid_pct = split_tf_preset ? (active_tf == "60" ? 28.0 : active_tf == "240" ? 38.0 : 48.0) : split_mid_manual

bool is_selected_tf = timeframe.period == active_tf
int tfMs = timeframe.in_seconds() * 1000

var box[] boxes = array.new_box()
var line[] lines = array.new_line()
var float[] tops = array.new_float()
var float[] bottoms = array.new_float()
var float[] mids = array.new_float()
var int[] leftTimes = array.new_int()
var int[] rightTimes = array.new_int()
var int[] firstBuyTimes = array.new_int()
var bool[] triggered = array.new_bool()
var int[] breakBars = array.new_int()
var int[] entryBars = array.new_int()
var float[] entryPrices = array.new_float()

var int total_trades = 0
var int win_trades = 0
var int loss_trades = 0
var float total_return = 0.0

bool sig_buy = false
bool sig_selltp = false
bool sig_sellsl = false

price_overlap_pct(float t1, float b1, float t2, float b2) =>
    float hi = math.min(t1, t2)
    float lo = math.max(b1, b2)
    float overlap = math.max(0.0, hi - lo)
    float h1 = t1 - b1
    float h2 = t2 - b2
    float base = math.max(h1, h2, syminfo.mintick)
    (overlap / base) * 100.0

time_near_overlap(int tL1, int tR1, int tL2, int tR2, int gapBars) =>
    int gap = gapBars * tfMs
    (tL1 <= tR2 + gap) and (tL2 <= tR1 + gap)

similar_range(float tA, float bA, float tB, float bB, float tol_pct) =>
    float tol = math.max(tA - bA, tB - bB) * (tol_pct / 100.0)
    math.abs(tA - tB) <= tol and math.abs(bA - bB) <= tol

bar_in_band(int idx, float top, float bot, float pad) =>
    high[idx] <= top + pad and low[idx] >= bot - pad

// 종가가 중심에서 splitPct%×반높이 이내일 때만 가로 확장 허용
bar_near_mid(int idx, float mid, float top, float bot, float splitPct) =>
    float halfH = (top - bot) * 0.5
    halfH <= syminfo.mintick ? true : math.abs(close[idx] - mid) <= (splitPct / 100.0) * halfH

bar_can_extend(int idx, float top, float bot, float mid, float pad, float splitPct) =>
    bar_in_band(idx, top, bot, pad) and bar_near_mid(idx, mid, top, bot, splitPct)

expand_range_idx(int seedLeft, int seedRight, float top, float bot, float mid, int maxBars, float pad, int gapAllow, float splitPct) =>
    int leftIdx = seedLeft
    int rightIdx = seedRight
    int miss = 0
    int lim = math.min(maxBars, bar_index - 1)
    if seedLeft < lim
        for i = seedLeft + 1 to lim
            if bar_can_extend(i, top, bot, mid, pad, splitPct)
                leftIdx := i
                miss := 0
            else
                miss += 1
                if miss >= gapAllow
                    break
    miss := 0
    for i = seedRight - 1 to 0
        if bar_can_extend(i, top, bot, mid, pad, splitPct)
            rightIdx := i
            miss := 0
        else
            miss += 1
            if miss >= gapAllow
                break
    [leftIdx, rightIdx]

recalc_box_prices(int leftIdx, int rightIdx) =>
    float t = high[rightIdx]
    float b = low[rightIdx]
    for i = rightIdx + 1 to leftIdx
        t := math.max(t, high[i])
        b := math.min(b, low[i])
    [t, b, (t + b) * 0.5]

f_lineEndT(int boxRightT, int buyT) =>
    na(buyT) ? boxRightT : buyT

merge_into(int idx, float newTop, float newBot, int newLeftT, int newRightT) =>
    float oldTop = array.get(tops, idx)
    float oldBot = array.get(bottoms, idx)
    float mTop = math.max(oldTop, newTop)
    float mBot = math.min(oldBot, newBot)
    float mMid = (mTop + mBot) * 0.5
    int mLeft = math.min(array.get(leftTimes, idx), newLeftT)
    int mRight = math.max(array.get(rightTimes, idx), newRightT)
    int buyT = array.get(firstBuyTimes, idx)
    array.set(tops, idx, mTop)
    array.set(bottoms, idx, mBot)
    array.set(mids, idx, mMid)
    array.set(leftTimes, idx, mLeft)
    array.set(rightTimes, idx, mRight)
    box bx = array.get(boxes, idx)
    line ln = array.get(lines, idx)
    box.set_top(bx, mTop)
    box.set_bottom(bx, mBot)
    box.set_lefttop(bx, mLeft, mTop)
    box.set_rightbottom(bx, mRight, mBot)
    line.set_xy1(ln, mLeft, mMid)
    line.set_xy2(ln, f_lineEndT(mRight, buyT), mMid)
    line.set_extend(ln, extend.none)
    idx

find_merge_index(float t, float b, int lT, int rT) =>
    int found = -1
    int n = array.size(boxes)
    if n > 0
        for j = 0 to n - 1
            float et = array.get(tops, j)
            float eb = array.get(bottoms, j)
            int el = array.get(leftTimes, j)
            int er = array.get(rightTimes, j)
            bool price_ok = price_overlap_pct(t, b, et, eb) >= merge_pct or similar_range(t, b, et, eb, 8.0)
            bool time_ok = time_near_overlap(lT, rT, el, er, merge_bars)
            if price_ok and time_ok
                found := j
                break
    found

if is_selected_tf and barstate.isconfirmed
    int lookback = max_expand_bars
    int valid_count = 0
    float max_val = high[1]
    float min_val = low[1]
    int start_idx = na
    for i = 1 to lookback
        max_val := math.max(max_val, high[i])
        min_val := math.min(min_val, low[i])
        float range_pct = min_val > 0 ? ((max_val - min_val) / min_val) * 100 : 100.0
        if range_pct <= max_box_pct
            valid_count += 1
            start_idx := i
        else
            break
    if valid_count >= min_days and not na(start_idx)
        float seedTop = max_val
        float seedBot = min_val
        float pad = (seedTop - seedBot) * (expand_edge_pct / 100.0)
        float seedMid = (seedTop + seedBot) * 0.5
        [leftIdx, rightIdx] = expand_range_idx(start_idx, 1, seedTop, seedBot, seedMid, lookback, pad, expand_gap_bars, split_mid_pct)
        [boxTop, boxBot, mid] = recalc_box_prices(leftIdx, rightIdx)
        float threshold = (boxTop - boxBot) * 0.12
        int top_touch = 0
        int bottom_touch = 0
        for i = rightIdx to leftIdx
            if high[i] >= boxTop - threshold
                top_touch += 1
            if low[i] <= boxBot + threshold
                bottom_touch += 1
        if top_touch >= 2 and bottom_touch >= 2
            int tLeft = time[leftIdx]
            int tRight = time[rightIdx]
            int mergeIdx = find_merge_index(boxTop, boxBot, tLeft, tRight)
            if mergeIdx >= 0
                merge_into(mergeIdx, boxTop, boxBot, tLeft, tRight)
            else
                box b = box.new(tLeft, boxTop, tRight, boxBot, xloc=xloc.bar_time, border_color=color.blue, border_width=2, bgcolor=color.new(color.blue, 90))
                line l = line.new(tLeft, mid, tRight, mid, xloc=xloc.bar_time, color=color.orange, width=1, extend=extend.none)
                array.push(boxes, b)
                array.push(lines, l)
                array.push(tops, boxTop)
                array.push(bottoms, boxBot)
                array.push(mids, mid)
                array.push(leftTimes, tLeft)
                array.push(rightTimes, tRight)
                array.push(firstBuyTimes, na)
                array.push(triggered, false)
                array.push(breakBars, na)
                array.push(entryBars, na)
                array.push(entryPrices, na)

int sz = array.size(boxes)
if sz > 0
    for i = 0 to sz - 1
        float top = array.get(tops, i)
        float bottom = array.get(bottoms, i)
        float mid = array.get(mids, i)
        bool trig = array.get(triggered, i)
        int brk = array.get(breakBars, i)
        float entry = array.get(entryPrices, i)
        if na(entry)
            if not trig and low <= bottom
                array.set(triggered, i, true)
                array.set(breakBars, i, bar_index)
            if trig and bar_index > brk and high >= mid
                array.set(entryPrices, i, mid)
                array.set(entryBars, i, bar_index)
                array.set(firstBuyTimes, i, time)
                total_trades += 1
                sig_buy := true
                label.new(bar_index, mid, "매수 #" + str.tostring(i), style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
        else
            if high >= top
                float ret = entry > 0 ? ((top - entry) / entry) * 100.0 : 0.0
                total_return += ret
                win_trades += 1
                sig_selltp := true
                label.new(bar_index, top, "익절 " + str.tostring(ret, "#.##") + "%", style=label.style_label_down, color=color.lime, textcolor=color.black, size=size.small)
                array.set(entryPrices, i, na)
                array.set(triggered, i, false)
            else if low <= bottom
                float ret = entry > 0 ? ((bottom - entry) / entry) * 100.0 : 0.0
                total_return += ret
                loss_trades += 1
                sig_sellsl := true
                label.new(bar_index, bottom, "손절 " + str.tostring(ret, "#.##") + "%", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
                array.set(entryPrices, i, na)
                array.set(triggered, i, false)

int liveSz = array.size(boxes)
if liveSz > 0
    for i = 0 to liveSz - 1
        box bx = array.get(boxes, i)
        line ln = array.get(lines, i)
        float top = array.get(tops, i)
        float bottom = array.get(bottoms, i)
        float mid = array.get(mids, i)
        bool hasPos = not na(array.get(entryPrices, i))
        int origRightT = array.get(rightTimes, i)
        int buyT = array.get(firstBuyTimes, i)
        float pad = (top - bottom) * (expand_edge_pct / 100.0)
        bool canExtendBox = bar_can_extend(0, top, bottom, mid, pad, split_mid_pct)
        int boxRightT = canExtendBox ? time : origRightT
        box.set_right(bx, boxRightT)
        int lineEndT = na(buyT) ? time : buyT
        line.set_xy1(ln, array.get(leftTimes, i), mid)
        line.set_xy2(ln, lineEndT, mid)
        line.set_extend(ln, extend.none)
        color borderCol = hasPos ? color.lime : color.blue
        color bgCol = hasPos ? color.new(color.green, 82) : color.new(color.blue, 90)
        box.set_border_color(bx, borderCol)
        box.set_bgcolor(bx, bgCol)
        line.set_color(ln, hasPos ? color.lime : color.orange)
        line.set_width(ln, hasPos ? 2 : 1)

plotshape(show_buy and sig_buy, title="매수", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, text="매수")
plotshape(show_sell and sig_selltp, title="매도 익절", style=shape.triangledown, location=location.abovebar, color=color.lime, size=size.small, text="익절")
plotshape(show_sell and sig_sellsl, title="매도 손절", style=shape.xcross, location=location.belowbar, color=color.red, size=size.tiny, text="손절")

float win_rate = total_trades > 0 ? (win_trades * 100.0 / total_trades) : 0.0
var table t = table.new(position.bottom_right, 2, 6, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(t, 0, 0, "박스 수", text_color=color.gray)
    table.cell(t, 1, 0, str.tostring(sz))
    table.cell(t, 0, 1, "TRADES", text_color=color.gray)
    table.cell(t, 1, 1, str.tostring(total_trades))
    table.cell(t, 0, 2, "WINRATE", text_color=color.gray)
    table.cell(t, 1, 2, str.tostring(win_rate, "#.##") + "%")
    table.cell(t, 0, 3, "WINS", text_color=color.gray)
    table.cell(t, 1, 3, str.tostring(win_trades))
    table.cell(t, 0, 4, "LOSSES", text_color=color.gray)
    table.cell(t, 1, 4, str.tostring(loss_trades))
    table.cell(t, 1, 5, str.tostring(total_return, "#.##") + "%")
