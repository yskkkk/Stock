{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/stock-ops-session-start.mjs"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/stock-ops-before-submit.mjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/stock-ops-pre-tool-visibility.mjs"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node .cursor/hooks/stock-ops-scroll-agent-bottom.mjs"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stock-ops-queue-release.mjs"
      },
      {
        "command": "node .cursor/hooks/stock-ops-scroll-agent-bottom.mjs"
      },
      {
        "command": "node .cursor/hooks/stock-ops-chat-no-code-notify.mjs"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/stock-ops-queue-release.mjs"
      },
      {
        "command": "node .cursor/hooks/stock-ops-chat-no-code-notify.mjs"
      }
    ]
  }
}
