# 모바일 앱(APK) 빌드 — 웹과 동일한 화면을 고정 URL WebView로 띄움
# 이 파일을 .env에 합치거나 아래 한 줄만 .env에 넣으세요.

# 필수: 사용자가 브라우저로 쓰는 Stock 주소(HTTPS 권장)
CAPACITOR_SERVER_URL=https://your-stock-server.example.com

# 위와 같으면 됨. 아래는 같은 값으로 써도 됩니다.
# APP_PUBLIC_BASE_URL=https://your-stock-server.example.com

# Android APK: npm run apk:build → public/downloads/stock-dashboard.apk
# iPhone IPA (Mac): IOS_DEVELOPMENT_TEAM=팀ID 후 npm run ipa:build
# IOS_DEVELOPMENT_TEAM=XXXXXXXXXX
# IOS_EXPORT_METHOD=development
