# =============================================================================
# YSTOCK 로컬 설정 — 이 파일을 복사해서 사용하세요.
#
#   복사 경로:  c:\Stock\.env
#   PowerShell:  Copy-Item .env.example .env
#
# .env 는 Git에 올라가지 않습니다. API 키는 .env 에만 넣으세요.
# =============================================================================

# --- BYOK 실매매 (Phase B) — 사용자별 키는 앱 «내 API 연동»에서 저장 ---------
# 32바이트 hex 또는 임의 문자열 (AES-256-GCM). 필수.
CREDENTIALS_MASTER_KEY=

# 첫 계정만 자동 가입 허용. 이후 가입 허용 시 1
# USER_REGISTRATION_ENABLED=1

# 기존 live-trade-programs.json (userId 없음) → 로그인 계정 귀속(1회)
# LIVE_TRADE_LEGACY_MIGRATE=1

# --- 빗썸 (레거시·scripts/bithumb-test-order.mjs 전용, 러너는 BYOK만 사용) ---
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=
BITHUMB_LIVE_ORDERS_ENABLED=0

# (선택) API 베이스 URL — 보통 비워 둠
# BITHUMB_API_BASE_URL=https://api.bithumb.com

# --- 토스 (국내 주식 실매매만 필요할 때) ------------------------------------
# TOSS_API_KEY=
# TOSS_API_SECRET=
# TOSS_ACCOUNT_ID=
# TOSS_LIVE_ORDERS_ENABLED=0

# --- 기타 (필요할 때만) ------------------------------------------------------
# PORT=3456
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_OPS_BOT_TOKEN=   # IDE 개발 완료·무코드 대화 종료 알림
# TELEGRAM_OPS_CHAT_ID=
# SERVER_OPEN_CLIENT_TELEGRAM=1   # 서버 오프라인 페이지에서 OPS 봇으로 직접 요청(토큰이 HTML에 주입됨). 0=비활성
# STOCK_CHAT_NO_CODE_TELEGRAM=0   # 끄면 «코드 없이 종료» 알림만 비활성
# OPENDART_API_KEY=
# CURSOR_API_KEY=
