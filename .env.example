# OpenDART API 인증키 — https://opendart.fss.or.kr

OPENDART_API_KEY=



# 텔레그램 알림 (@BotFather 토큰, 채팅/그룹 chat_id)

TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

# TELEGRAM_MIN_SCORE=6

# SCREEN_INTERVAL_MS=60000

# 조회 속도 (기본: 병렬 4·간격 250ms·스크린 6종목 동시)
# YAHOO_MAX_CONCURRENT=4
# YAHOO_REQUEST_GAP_MS=250
# SCREEN_CONCURRENCY=6

# ---------------------------------------------------------------------------
# IP 접근 제어 (기본: 켜짐 — 허가 IP만 스크리너 API 사용)
# ---------------------------------------------------------------------------
# 완전 공개(누구나 스크리너)로 쓰려면 아래만 1로 두세요.
# ACCESS_CONTROL_DISABLED=1
#
# 명시적으로 끄는 다른 방법:
# ACCESS_CONTROL_ENABLED=0
#
# 관리자(승인/거절/허가 취소) — Bearer 토큰. 운영에서는 반드시 임의 긴 문자열로 설정.
# npm run dev(Vite)에서 비워 두면 개발용 기본 토큰이 쓰입니다(콘솔 경고 참고).
# ACCESS_ADMIN_TOKEN=
#
# 개발 기본 관리 토큰(ACCESS_ADMIN_TOKEN 없을 때만): dev-stock-access-admin-change-in-env
#
# 항상 허용할 IP(쉼표 구분)
# ACCESS_BOOTSTRAP_IPS=
#
# 로컬(127.0.0.1) 자동 허용 — 기본 0(차단). PC에서 스크리너까지 편히 쓰려면 1
# ACCESS_ALLOW_LOCALHOST=1

