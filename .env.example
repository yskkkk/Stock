# =============================================================================
# YSTOCK 로컬 설정 — 이 파일을 복사해서 사용하세요.
#
#   복사 경로:  c:\Stock\.env
#   PowerShell:  Copy-Item .env.example .env
#
# .env 는 Git에 올라가지 않습니다. API 키는 .env 에만 넣으세요.
# =============================================================================

# --- BYOK 실매매 (Phase B) — 사용자별 키는 앱 «내 API 연동»에서 저장 ---------
# 32바이트 hex 또는 임의 문자열 (AES-256-GCM). 필수.
CREDENTIALS_MASTER_KEY=

# 첫 계정만 자동 가입 허용. 이후 가입 허용 시 1
# USER_REGISTRATION_ENABLED=1

# --- 회원가입 이메일 인증 (SMTP) · 가입·알림 수신 주소 -------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=your@gmail.com
# SMTP_PASS=앱_비밀번호
# 수신함 표시 이름만 (이메일 주소는 안 보이게)
# SMTP_FROM_NAME=YSTOCK
# (선택) 발신 주소 — 비우면 SMTP_USER로만 인증, 목록에는 이름만 표시
# SMTP_FROM_ADDRESS=
# (선택) 답장 받을 주소 — 비우면 Reply-To 없음
# SMTP_REPLY_TO=
# 로컬만: 메일 대신 콘솔에 인증번호 출력
# EMAIL_VERIFY_MOCK=1

# 실매매 — 빗썸 잔고·체결 동기화 주기(ms, 기본 10000). 0=폴러 끔
# STOCK_LIVE_TRADE_EXCHANGE_SYNC=0
# STOCK_LIVE_TRADE_EXCHANGE_SYNC_MS=10000

# 기존 live-trade-programs.json (userId 없음) → 로그인 계정 귀속(1회)
# LIVE_TRADE_LEGACY_MIGRATE=1

# --- 빗썸 (레거시·scripts/bithumb-test-order.mjs 전용, 러너는 BYOK만 사용) ---
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=
BITHUMB_LIVE_ORDERS_ENABLED=0

# (선택) API 베이스 URL — 보통 비워 둠
# BITHUMB_API_BASE_URL=https://api.bithumb.com

# --- 토스 (국내 주식 실매매만 필요할 때) ------------------------------------
# TOSS_API_KEY=
# TOSS_API_SECRET=
# TOSS_ACCOUNT_ID=
# TOSS_LIVE_ORDERS_ENABLED=0

# --- 기타 (필요할 때만) ------------------------------------------------------
# PORT=3456
# TELEGRAM_BOT_TOKEN=
# 주식 알림 — 텔레그램 채널(권장). 봇을 채널 관리자로 추가·«메시지 게시» 권한
# TELEGRAM_CHANNEL_ID=-1001234567890
# (선택) @공개채널username 도 가능
# (구) 개인 DM만: TELEGRAM_CHAT_ID=숫자 chat_id
# (선택) 채널+개인 동시: TELEGRAM_CHANNEL_ID 설정 + TELEGRAM_STOCK_NOTIFY_DM=1 + TELEGRAM_CHAT_ID
# TELEGRAM_OPS_BOT_TOKEN=   # IDE 개발 완료·무코드 대화 종료 알림
# TELEGRAM_OPS_CHAT_ID=
# SERVER_OPEN_CLIENT_TELEGRAM=1   # 서버 오프라인 페이지에서 OPS 봇으로 직접 요청(토큰이 HTML에 주입됨). 0=비활성
# STOCK_CHAT_NO_CODE_TELEGRAM=0   # 끄면 «코드 없이 종료» 알림만 비활성
# OPENDART_API_KEY=
# CURSOR_API_KEY=
