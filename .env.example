# OpenDART API 인증키 — https://opendart.fss.or.kr

OPENDART_API_KEY=



# ── 주식 종목 추천 알림 (@YSK_STOCK_RECOMMEND_BOT 만 — 여기 토큰 넣기)
# 서버는 sendMessage 만 사용(수신·웹훅·getUpdates 폴링 없음). 기동 시 deleteWebhook 으로 웹훅도 해제.
# 텔레그램 앱에서 봇에게 DM을 보낼 수는 있으나 Stock 서버는 읽거나 답하지 않음.
# “완전 일방” 운영: 채널에 봇을 관리자로 두거나, 그룹만 쓰고 BotFather /setprivacy Enable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 웹 에이전트 (@YSK_WEB_AGENT_USE_HISTORY_BOT — 주식 봇·채팅과 분리 필수)
# 서버 기동·종료 ON/OFF 텔레그램 알림 — 기본 끔. 켜려면 1
# OPS_SERVER_LIFECYCLE_TELEGRAM=0
TELEGRAM_OPS_BOT_TOKEN=
# chat_id: 해당 봇을 그 방에 넣고 메시지 1통 → `node scripts/telegram-list-chat-ids.mjs ops`
TELEGRAM_OPS_CHAT_ID=

# 텔레그램「종목 보기」버튼 — HTTPS 공개 URL만 (http://127.0.0.1 등은 API 오류 → 버튼 생략)
# APP_PUBLIC_BASE_URL=https://your-domain.com
# iPhone IPA OTA·텔레그램 링크 — IP(182.x.x.x) 불가, 공인 HTTPS 도메인만
# CAPACITOR_SERVER_URL=https://your-domain.com
# Node 직접 HTTPS (리버스프록시 없을 때): win-acme·certbot PEM 경로
# STOCK_TLS_CERT_PATH=
# STOCK_TLS_KEY_PATH=
# HTTPS_PORT=443

# 경제 지표 카드「예상치」— Finnhub 경제 캘린더 estimate(시장 컨센서스) 자동 병합 (선택)
# https://finnhub.io/register — 무료 키로 calendar/economic 조회
# FINNHUB_API_KEY=

# 경제 지표 발표 약 1시간 전·약 10분 전 텔레그램 예고 (기본: 봇 설정 시 켜짐)
# TELEGRAM_MACRO_REMINDERS=0
# TELEGRAM_MACRO_REMINDER_INTERVAL_MS=45000

# TELEGRAM_MIN_SCORE=7

# 관리자 IP(쉼표) — 이 IP로 접속 시 상단 관리자 메뉴·IP/불편/텔레그램 관리 전부 (Bearer 없이 가능)
# ACCESS_ADMIN_IPS=
# (구) TELEGRAM_RESET_ADMIN_IPS 만 있어도 동일 목록으로 인식합니다.

# 알림 초기화는 위 ACCESS_ADMIN_IPS(또는 구 TELEGRAM_RESET_ADMIN_IPS) 또는 ACCESS_ADMIN_TOKEN 으로 통합됨
# TELEGRAM_RESET_ADMIN_IPS=

# SCREEN_INTERVAL_MS=60000

# dev(Vite 5173) 기동 시 같은 포트 점유 프로세스 강제 종료 — 끄려면 0
# STOCK_DEV_KILL_PORT=0

# 조회 속도 (기본: 병렬 4·간격 250ms·스크린 6종목 동시)
# YAHOO_MAX_CONCURRENT=4
# YAHOO_REQUEST_GAP_MS=250
# SCREEN_CONCURRENCY=6

# ---------------------------------------------------------------------------
# IP 접근 제어 (기본: 꺼짐 — 누구나 API·운영 탭, 접속 IP는 모두 관리자 권한)
# ---------------------------------------------------------------------------
# IP 허용제를 켜려면:
# ACCESS_CONTROL_ENABLED=1
#
# 공개 모드 명시(기본과 동일):
# ACCESS_CONTROL_DISABLED=1
#
# 관리자(승인/거절/허가 취소) — Bearer 토큰. ACCESS_ADMIN_IPS만 쓰는 경우 비워 둘 수 있음.
# ACCESS_ADMIN_TOKEN=
# 서버 재기동(관리자 UI) 전용 비밀번호 — 없으면 ACCESS_ADMIN_TOKEN 과 동일 값 사용
# SERVER_RESTART_PASSWORD=
# 항상 허용할 IP(쉼표 구분)
# ACCESS_BOOTSTRAP_IPS=
#
# 로컬(127.0.0.1) 자동 허용 — 기본 0(차단). PC에서 스크리너까지 편히 쓰려면 1
# ACCESS_ALLOW_LOCALHOST=1

# ---------------------------------------------------------------------------
# 불편 접수함 (우측 상단 '불편' 버튼) — 목록 열람 시 Bearer 로 사용할 비밀 토큰
# ---------------------------------------------------------------------------
# FEEDBACK_INBOX_TOKEN=

# ---------------------------------------------------------------------------
# 개발 대기열 (IDE·웹 FIFO) — 지연 조정
# ---------------------------------------------------------------------------
# 에이전트 실행 이력 — server/.data/ops-cursor-agent-history.json (재기동 후 유지, 기본 최대 500건)
# OPS_AGENT_HISTORY_MAX=500

# STOCK_DEV_QUEUE_SYNC_MS=100
# STOCK_IDE_TURN_END_IDLE_MS=4000
# STOCK_IDE_HOOK_GRANT_WAIT_MS=600000
# VITE_OPS_DEV_QUEUE_POLL_MS=250
# 개발 완료 텔레그램 중복 방지(ms). auto-git는 완료 알림 후 8분간 같은 HEAD 생략
# 동일 완료 알림 중복 방지(ms, 기본 5분) — Vite 재기동·훅+폴러 동시 flush 시 1통만
# OPS_DEV_NOTIFY_DEDUP_MS=300000
# OPS_AUTOGIT_NOTIFY_SUPPRESS_AFTER_COMPLETION_MS=480000
# 개발 완료 알림 모아서 마지막 1통만 (ms, 기본 12초 · IDE/에이전트 완료는 2초)
# OPS_DEV_NOTIFY_DEBOUNCE_MS=12000
# OPS_DEV_NOTIFY_COALESCE=0

# ---------------------------------------------------------------------------
# 모바일 앱(APK) — 브라우저와 같은 웹을 WebView로 띄움 (apk:build 시 필수)
# ---------------------------------------------------------------------------
# CAPACITOR_SERVER_URL=https://your-stock-server.example.com
# (템플릿: .env.mobile.example)  → npm run apk:build

# ---------------------------------------------------------------------------
# 서버 자가 개선 백로그 — SERVER_IMPROVEMENTS.md 자동 갱신
# ---------------------------------------------------------------------------
# STOCK_SELF_IMPROVEMENT=0
# STOCK_SELF_IMPROVEMENT_PROBE_MS=300000

# ---------------------------------------------------------------------------
# 운영 탭 — Cursor 에이전트 (관리자만 /api/ops/cursor-agent 호출 가능)
# https://cursor.com/docs — API 키 발급 후 로컬 에이전트 실행에 사용
# ---------------------------------------------------------------------------
# CURSOR_API_KEY=
# 선택: 로컬 에이전트 모델 id (기본 composer-2)
# CURSOR_AGENT_MODEL=
# 선택: ripgrep 절대 경로 — 비우면 프로젝트의 @vscode/ripgrep로 자동 설정
# CURSOR_RIPGREP_PATH=

# ---------------------------------------------------------------------------
# 서버가 Git 원격과 주기적으로 맞추고, 새 커밋이 있으면 pull 후 프로세스 재시작
# (기본: 꺼짐 — 운영 서버에서만 1로 두는 것을 권장)
# ---------------------------------------------------------------------------
# AUTO_GIT_SYNC=1
# pull 성공 시 ops 텔레그램에 커밋·파일 요약 (기본 켜짐, 끄려면 0)
# AUTO_GIT_TELEGRAM_NOTIFY=0
# 로컬 수정이 있어도 pull 되게(충돌 시 수동 처리)
# AUTO_GIT_STASH_BEFORE_PULL=1
# AUTO_GIT_SYNC_INTERVAL_MS=60000
# AUTO_GIT_REMOTE=origin
# AUTO_GIT_BRANCH=main
# 새 커밋 pull 후: npm ci(또는 install) + npm run build(백·프론트 전체)까지 자동. 끄려면:
# AUTO_GIT_SKIP_NPM_REFRESH=1
# 위 단계 뒤 추가 셸 한 줄 (선택)
# AUTO_GIT_POST_PULL_CMD=
# pull 후 npm/build·후크가 실패해도 재시작은 함(기본). 예전처럼 빌드·후크 성공 시에만 재시작하려면:
# AUTO_GIT_RESTART_ONLY_IF_BUILD_OK=1

# 국내 주식 최신가 — Naver polling(정규·시간외). 끄면 Yahoo 1분봉만(15:30 이후 갱신 안 될 수 있음)
# KR_NAVER_QUOTE=1
# KR_NAVER_QUOTE_TTL_MS=30000

# ---------------------------------------------------------------------------
# 토스증권 Open API — 실매매 탭 (공식 스펙 반영 후 TOSS_API_BASE_URL 조정)
# ---------------------------------------------------------------------------
# TOSS_API_KEY=
# TOSS_API_SECRET=
# TOSS_ACCOUNT_ID=
# TOSS_API_BASE_URL=
# 실제 주문 전송(미설정 시 서버 로그 시뮬레이션만): TOSS_LIVE_ORDERS_ENABLED=1

