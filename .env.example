# =============================================================================
# YSTOCK 로컬 설정 — 이 파일을 복사해서 사용하세요.
#
#   복사 경로:  c:\Stock\.env
#   PowerShell:  Copy-Item .env.example .env
#
# .env 는 Git에 올라가지 않습니다. API 키는 .env 에만 넣으세요.
# =============================================================================

# --- 빗썸 (코인 실매매) — 아래 두 줄만 채우면 연동 표시됨 -------------------
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=

# 0 = 빗썸에 주문 안 함(앱에 시뮬만). 확인 후 실주문 시 1
BITHUMB_LIVE_ORDERS_ENABLED=0

# (선택) API 베이스 URL — 보통 비워 둠
# BITHUMB_API_BASE_URL=https://api.bithumb.com

# --- 토스 (국내 주식 실매매만 필요할 때) ------------------------------------
# TOSS_API_KEY=
# TOSS_API_SECRET=
# TOSS_ACCOUNT_ID=
# TOSS_LIVE_ORDERS_ENABLED=0

# --- 기타 (필요할 때만) ------------------------------------------------------
# PORT=3456
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# OPENDART_API_KEY=
# CURSOR_API_KEY=
